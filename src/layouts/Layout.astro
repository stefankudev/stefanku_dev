---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Stefan Kudev - Developer',
  description = "Stefan Kudev's personal portfolio website",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=0.5, user-scalable=0"
    />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />
    <link rel="apple-touch-icon" href="/logo192.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @use '../styles/variables' as *;
  @use '../styles/typography';
  @use '../styles/scrollbar';
  @use '../styles/animations';
  @use '../styles/utilities';

  html {
    min-height: 100%;
  }

  body {
    background: linear-gradient(90deg, #2a3035, #171a1d);
    background-size: calc(100vw) 100%;
    height: 100%;
    width: calc(100% - 0.63rem);
    overflow-x: hidden;
    margin: 0;
  }

  main {
    padding: 1.25rem;
    font-family: var(--font-family-body);
    min-width: 35rem !important;
    transition: opacity var(--transition-slow), transform var(--transition-slow);
  }

  .blur {
    filter: blur(2.5em) !important;
    user-select: none;
    pointer-events: none;
  }

  .footer {
    color: var(--color-text-primary);
  }
</style>
