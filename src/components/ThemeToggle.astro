---
---

<button
  class="theme-toggle"
  type="button"
  aria-label="Switch to light/dark theme"
  title="Toggle theme"
>
  <span class="theme-toggle__icon">
    <svg class="theme-toggle__icon-moon" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/>
    </svg>
    <svg class="theme-toggle__icon-sun" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
    </svg>
  </span>
</button>

<style lang="scss">
  .theme-toggle {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 1000;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 0.1rem solid var(--color-border-default);
    border-radius: var(--radius-default);
    background: var(--color-bg-button);
    cursor: pointer;
    transition: border-color var(--transition-default), background var(--transition-default);

    &:hover {
      border-color: var(--color-border-strong);
      background: var(--color-bg-card-hover);
    }

    &:focus-visible {
      outline: 0.2rem solid var(--color-accent-primary);
      outline-offset: 0.15rem;
    }

    &__icon {
      position: relative;
      width: 1.25rem;
      height: 1.25rem;

      svg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        fill: var(--color-text-primary);
        transition: transform 0.4s ease, opacity 0.4s ease;
      }

      &-moon {
        opacity: 1;
        transform: rotate(0deg);
      }

      &-sun {
        opacity: 0;
        transform: rotate(-90deg);
      }
    }
  }

  :global([data-theme="light"]) {
    .theme-toggle__icon {
      &-moon {
        opacity: 0;
        transform: rotate(90deg);
      }

      &-sun {
        opacity: 1;
        transform: rotate(0deg);
      }
    }
  }
</style>

<script>
  const toggle = document.querySelector('.theme-toggle');
  toggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.dataset.theme;
    const next = current === 'light' ? 'dark' : 'light';
    html.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
